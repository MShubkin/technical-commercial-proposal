SRV_HOST=0.0.0.0
SRV_PORT=3078


# accepted values:
# 1 = prod logger (CEF) if this is selected we
# need `LOGGER_DIR` and `LOGGER_CEF_FILE` variables set.
# 2 = dev logger ()
# Any other = No logger.
LOGGER_MODE=cef
# relative dir to self
LOGGER_DIR=logs
LOGGER_FILE=log.cef

RABBITMQ_HOST=localhost
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_RETRIES=10
RABBITMQ_INTERVAL_MS=100

# Address of the plan server if the service supports it.
PLAN_DB_HOST=127.0.0.1
PLAN_DB_PORT=3004

# The total thread count of the service if it supports the setting.
SRV_THREAD_COUNT=7

# postgres params
# POSTGRES_VHOST=rcdevstand.inlinegroup.ru
# POSTGRES_PORT=5432
# POSTGRES_DB=asez_testing_dbtkp
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changeme
# POSTGRES_MIN_CONNECTIONS=1
# POSTGRES_MAX_CONNECTIONS=4
# POSTGRES_TIMEOUT_S=10
# POSTGRES_CONNECTION_REFRESH_S=3600

 POSTGRES_VHOST=localhost
 POSTGRES_PORT=5432
 POSTGRES_DB=postgres
 POSTGRES_USER=postgres
 POSTGRES_PASSWORD=postgres
 POSTGRES_MIN_CONNECTIONS=1
 POSTGRES_MAX_CONNECTIONS=4
 POSTGRES_TIMEOUT_S=10
 POSTGRES_CONNECTION_REFRESH_S=3600

RUST_LOG=debug

MONOLITH_BASE_URL=http://localhost:8080
MASTER_DATA_BASE_URL=http://localhost:9071
MONOLITH_TECH_USER_ID=10200
